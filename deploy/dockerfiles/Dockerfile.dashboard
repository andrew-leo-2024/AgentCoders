# Dashboard Dockerfile (React + Vite)
FROM node:22-slim AS build
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/dashboard/package.json packages/dashboard/
RUN corepack enable && pnpm install --frozen-lockfile

COPY packages/dashboard/ packages/dashboard/
RUN pnpm --filter @agentcoders/dashboard build

# Serve with nginx
FROM nginx:alpine AS production
COPY --from=build /app/packages/dashboard/dist /usr/share/nginx/html
COPY deploy/dockerfiles/nginx-dashboard.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
