# Billing Service Dockerfile
FROM node:22-slim AS build
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json packages/shared/
COPY packages/billing-service/package.json packages/billing-service/
RUN corepack enable && pnpm install --frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/billing-service/ packages/billing-service/
RUN pnpm --filter @agentcoders/shared build \
    && pnpm --filter @agentcoders/billing-service build

FROM node:22-slim AS production
RUN groupadd -r app && useradd -r -g app app
WORKDIR /app

COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/packages/shared/dist ./packages/shared/dist
COPY --from=build /app/packages/shared/package.json ./packages/shared/
COPY --from=build /app/packages/billing-service/dist ./packages/billing-service/dist
COPY --from=build /app/packages/billing-service/package.json ./packages/billing-service/

USER app
EXPOSE 8081
CMD ["node", "packages/billing-service/dist/dwi-tracker.js"]
