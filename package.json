{
  "name": "agentcoders",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @agentcoders/shared db:generate",
    "db:migrate": "pnpm --filter @agentcoders/shared db:migrate",
    "db:push": "pnpm --filter @agentcoders/shared db:push"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "testcontainers": "^11.12.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
