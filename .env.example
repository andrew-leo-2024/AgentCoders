# ===========================================================================
# AgentCoders Environment Configuration
# ===========================================================================
# Copy to .env and fill in values. Fields marked [required] must be set.
# Fields with defaults shown can be omitted to use the default.

# ---------------------------------------------------------------------------
# Core (all services)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://agentcoders:password@localhost:5432/agentcoders  # [required]
REDIS_URL=redis://localhost:6379                  # default: redis://localhost:6379
LOG_LEVEL=info                                    # trace|debug|info|warn|error|fatal
NODE_ENV=development                              # development|staging|production

# ---------------------------------------------------------------------------
# SCM Provider — choose one: "ado" or "github"
# ---------------------------------------------------------------------------
SCM_PROVIDER=github                               # default: ado

# GitHub (required when SCM_PROVIDER=github)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Azure DevOps (required when SCM_PROVIDER=ado)
# ADO_ORG_URL=https://dev.azure.com/your-org
# ADO_PROJECT=your-project
# ADO_PAT=your-personal-access-token
# ADO_REPOSITORY_ID=your-repo-id                 # optional, defaults to ADO_PROJECT

# ---------------------------------------------------------------------------
# Claude AI
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...                      # [required]
CLAUDE_MODEL_CODING=claude-sonnet-4-6             # default: claude-sonnet-4-6
CLAUDE_MODEL_TRIAGE=claude-haiku-4-5-20251001     # default: claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Agent Runtime
# ---------------------------------------------------------------------------
AGENT_ID=agent-001                                # [required] unique per agent pod
TENANT_ID=00000000-0000-0000-0000-000000000001    # [required] UUID
AGENT_VERTICAL=backend                            # [required] e.g. backend, frontend, infra
AGENT_NAMESPACE=tenant-acme-backend               # [required] K8s namespace
POLL_INTERVAL_MS=30000                            # default: 30000 (30s)
CLAUDE_CODE_TIMEOUT_MS=900000                     # default: 900000 (15min)
MAX_TURNS_CODING=25                               # default: 25
MAX_TURNS_REVIEW=15                               # default: 15
DAILY_BUDGET_USD=100                              # default: 100
MONTHLY_BUDGET_USD=2000                           # default: 2000
HEALTH_PORT=8080                                  # default: 8080

# ---------------------------------------------------------------------------
# Telegram Gateway
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token                 # [required]
TELEGRAM_OWNER_CHAT_ID=your-chat-id               # [required]

# ---------------------------------------------------------------------------
# Billing Service
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...                     # [required]
STRIPE_WEBHOOK_SECRET=whsec_...                   # [required]
# HEALTH_PORT=8081                                # default: 8081

# ---------------------------------------------------------------------------
# Tenant Manager
# ---------------------------------------------------------------------------
API_KEY_SECRET=your-secret-key-minimum-32-chars!! # [required] min 32 characters
K8S_IN_CLUSTER=false                              # default: true (set false for local dev)
# HEALTH_PORT=8082                                # default: 8082

# ---------------------------------------------------------------------------
# Model Router (optional sidecar)
# ---------------------------------------------------------------------------
# DEFAULT_PROVIDER=anthropic                      # anthropic|openai|google|ollama
# DEFAULT_STRATEGY=quality-optimized              # cost-optimized|quality-optimized|latency-optimized|round-robin
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# OLLAMA_BASE_URL=http://localhost:11434
# RATE_LIMIT_RPM=60

# ---------------------------------------------------------------------------
# Enhancement Layer (optional)
# ---------------------------------------------------------------------------
# MAX_REFINEMENT_LOOPS=3
# CONFIDENCE_THRESHOLD=0.7
# MAX_COST_PER_ENHANCEMENT_USD=5.0
# SECURITY_SCAN_ENABLED=true
# PII_DETECTION_ENABLED=true

# ---------------------------------------------------------------------------
# Governance (optional)
# ---------------------------------------------------------------------------
# AUDIT_FLUSH_INTERVAL_MS=5000
# TELEMETRY_FLUSH_INTERVAL_MS=10000
# FAILURE_PATTERN_WINDOW_MS=3600000
# AUTHORITY_DECAY_CHECK_INTERVAL_MS=60000

# ---------------------------------------------------------------------------
# Jarvis CEO Runtime
# ---------------------------------------------------------------------------
# JARVIS_NAMESPACE=jarvis                         # default: jarvis
# TELEGRAM_CHAT_ID=your-chat-id                   # same as TELEGRAM_OWNER_CHAT_ID
# AGENT_IMAGE=agentcoders/agent-runtime:latest
# DAILY_SUMMARY_INTERVAL_MS=86400000              # default: 24h
